---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo" title={SITE_TITLE}>
			<svg width="auto" height="3rem" viewBox="0 0 55 99">
				<g transform="matrix(1,0,0,1,-8,-8)">
					<path fill="currentColor" d="M17.34,15.472L17.34,60.302L8,60.302L8,8L22.945,8C28.102,8 32.283,12.181 32.283,17.338L32.283,60.302L22.943,60.302L22.943,15.472L17.34,15.472ZM52.83,15.472L47.226,15.472L47.226,60.302L37.887,60.302L37.887,17.338C37.887,12.181 42.067,8 47.225,8L62.17,8L62.17,60.302L52.83,60.302L52.83,15.472ZM17.338,107C12.181,107 8,102.819 8,97.662L8,77.112C8,71.954 12.181,67.774 17.338,67.774L32.283,67.774L32.283,78.981L22.943,78.981L22.943,75.245L17.34,75.245L17.34,99.528L24.813,99.528C28.939,99.528 32.283,102.873 32.283,106.998L32.283,107L17.338,107ZM52.83,92.057L52.83,67.774L62.17,67.774L62.17,93.074L53.764,93.074L53.764,98.5L62.17,98.5L62.17,107L52.83,107L52.83,99.528L47.226,99.528L47.226,107L37.887,107L37.887,98.5L46.292,98.5L46.292,93.074L37.887,93.074L37.887,67.774L47.226,67.774L47.226,92.057L52.83,92.057Z"/>
				</g>
			</svg>
		</a>
	
		<div class="internal-links">
			<HeaderLink href="/">About</HeaderLink>
			<HeaderLink href="/project">Project</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
		</div>

		<div class="social-links">
			
			<a href="https://github.com/azreenbd" target="_blank">
				<span class="sr-only">Find me on GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="1.5rem" height="1.5rem"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
			<a href="https://www.linkedin.com/in/azreenbd" target="_blank">
				<span class="sr-only">Find me on LinkedIn</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="1.5rem" height="1.5rem"
					><path
						fill="currentColor"
						d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		position: fixed;
		top: 0;
		width: 100%;
		display: block;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: .25rem .5rem;
		background-color: black;
	}
	nav a {
		padding: 0.5em;
		color: #fff;
		text-decoration: none;
		font-family: "Barlow Semi Condensed", sans-serif;
	}
	nav a.active {
		text-decoration: none;
	}
	.logo {
		/* background-color: rgba(var(--accent-rgb), .75); */
		transition: 1s;
		border-radius: calc(var(--border-radius) - .5rem);
		padding: .4em .2em !important;
		line-height: 0;
	}
	/* .logo:hover {
		background-color: rgba(var(--accent-rgb), 1);
	} */
	.logo svg {
		color: #fff;
		height: 100%;
	}
	.internal-links {
		display: flex;
		margin: 0 1em;
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
		.logo {
		}
	}
</style>
