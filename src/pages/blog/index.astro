---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";

const posts = (await getCollection("blog", (p) => !p.data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Blog"
  description="Notes and writing by Naszrul Azreen Badarudin."
>
  <header class="border-b border-border pb-6">
    <h1 class="text-4xl uppercase">Blog</h1>
    <p class="mt-2 text-fg-muted">Notes, write-ups and the occasional idea.</p>
  </header>

  {
    posts.length === 0 ? (
      <p class="mt-8 text-fg-muted">No posts yet — check back soon.</p>
    ) : (
      <div class="mt-8 grid gap-5 sm:grid-cols-2">
        {posts.map((p) => (
          <BlogCard
            href={`/blog/${p.id}`}
            title={p.data.title}
            description={p.data.description}
            pubDate={p.data.pubDate}
            tags={p.data.tags}
          />
        ))}
      </div>
    )
  }
</BaseLayout>
