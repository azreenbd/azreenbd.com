---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Logo from "../components/Logo.astro";
import ProjectCard from "../components/ProjectCard.astro";
import BlogCard from "../components/BlogCard.astro";
import SocialLinks from "../components/SocialLinks.tsx";
import { SITE, SKILLS, SOCIALS } from "../config";

// Featured projects for the homepage
const projects = (await getCollection("projects", (p) => !p.data.draft))
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.order - a.data.order)
  .slice(0, 3);

// Latest posts
const posts = (await getCollection("blog", (p) => !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);
---

<BaseLayout>
  <!-- Hero -->
  <section>
    <div class="flex flex-col items-start gap-8 py-8 sm:flex-row">
      <Logo class="h-28 w-auto shrink-0" />
      <div>
        <h1 class="text-4xl uppercase leading-none sm:text-5xl font-semibold">
          Naszrul Azreen
          <span class="block text-brand">Badarudin</span>
        </h1>
        <p class="mt-3 text-xl text-fg-muted">{SITE.title}</p>
      </div>
    </div>
    <div>
      <ul class="mt-4 flex flex-wrap gap-2">
        {
          SKILLS.map((skill) => (
            <li class="rounded-full border border-border px-3 py-1 text-sm text-fg-muted">
              {skill}
            </li>
          ))
        }
      </ul>
      <div class="mt-6">
        <SocialLinks socials={SOCIALS} client:visible />
      </div>
    </div>
    
  </section>

  <!-- Featured projects -->
  <section class="mt-16">
    <div class="flex items-baseline justify-between">
      <h2 class="text-2xl font-semibold">Featured Projects</h2>
      <a href="/projects" class="text-sm  text-brand hover:underline">
        View all →
      </a>
    </div>
    <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        projects.map((p) => (
          <ProjectCard
            href={`/projects/${p.id}`}
            title={p.data.title}
            description={p.data.description}
            tags={p.data.tags}
            cover={p.data.cover}
            year={p.data.year}
          />
        ))
      }
    </div>
  </section>

  <!-- Latest posts -->
  {
    posts.length > 0 && (
      <section class="mt-16">
        <div class="flex items-baseline justify-between">
          <h2 class="text-2xl font-semibold">Blog</h2>
          <a href="/blog" class="text-sm text-brand hover:underline">
            View all →
          </a>
        </div>
        <div class="mt-6 grid gap-5 sm:grid-cols-2">
          {posts.map((p) => (
            <BlogCard
              href={`/blog/${p.id}`}
              title={p.data.title}
              description={p.data.description}
              pubDate={p.data.pubDate}
              tags={p.data.tags}
            />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
